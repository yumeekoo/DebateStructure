digraph er_full {
  rankdir=LR;
  graph [fontname="Arial", nodesep=0.4, ranksep=1.3, compound=true,
         label="EzMon — ER TOÀN CẢNH (21 bảng + 2 bảng pha sau). A=Master · B=Core · C=Extension(CTI) · D=Child",
         labelloc="t", fontsize=18];
  node [shape=plaintext, fontname="Arial", fontsize=10];
  edge [fontname="Arial", fontsize=8, color="#888888", arrowsize=0.7,
        dir=both, arrowtail=crow, arrowhead=tee];

  // ============ A · MASTER / DOMAIN ============
  subgraph cluster_A {
    label="A · MASTER / DOMAIN"; style="rounded,filled"; fillcolor="#eaf2fb"; fontsize=13; color="#2c5f8a";
    branch [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>branch</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">code</td><td align="left">text</td><td>UQ</td></tr><tr><td align="left">name</td><td align="left">text</td><td></td></tr></table>>];
    department [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>department</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">branch_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">code</td><td align="left">text</td><td></td></tr><tr><td align="left">name</td><td align="left">text</td><td></td></tr></table>>];
    room [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>room</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">department_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">code</td><td align="left">text</td><td></td></tr><tr><td align="left">name</td><td align="left">text</td><td></td></tr><tr><td align="left">function</td><td align="left">text</td><td></td></tr></table>>];
    staff [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>staff</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">branch_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">department_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">full_name</td><td align="left">text</td><td></td></tr><tr><td align="left">role</td><td align="left">text</td><td></td></tr><tr><td align="left">is_active</td><td align="left">bool</td><td></td></tr></table>>];
    patient [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>patient</b> (MPI toàn cục)</font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">patient_code</td><td align="left">text</td><td>UQ</td></tr><tr><td align="left">full_name</td><td align="left">text</td><td></td></tr><tr><td align="left">birth_date</td><td align="left">date</td><td></td></tr><tr><td align="left">gender</td><td align="left">text</td><td></td></tr><tr><td align="left">phone</td><td align="left">text</td><td></td></tr><tr><td align="left">national_id</td><td align="left">text</td><td></td></tr></table>>];
    service [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#2c5f8a"><font color="white"><b>service</b> (cây phân cấp)</font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">parent_id</td><td align="left">uuid</td><td>FK self</td></tr><tr><td align="left">code</td><td align="left">text</td><td>UQ</td></tr><tr><td align="left">name</td><td align="left">text</td><td></td></tr><tr><td align="left">price_bh</td><td align="left">num</td><td></td></tr><tr><td align="left">price_vp</td><td align="left">num</td><td></td></tr><tr><td align="left">is_group</td><td align="left">bool</td><td></td></tr></table>>];
  }

  // ============ B · WORK-GRAPH CORE ============
  subgraph cluster_B {
    label="B · WORK-GRAPH CORE (trái tim)"; style="rounded,filled"; fillcolor="#e8f6ed"; fontsize=13; color="#1f6f3f";
    node_type [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#1f6f3f"><font color="white"><b>node_type</b></font></td></tr><tr><td align="left">code</td><td align="left">text</td><td>PK</td></tr><tr><td align="left">name</td><td align="left">text</td><td></td></tr><tr><td align="left">axis</td><td align="left">text</td><td></td></tr></table>>];
    T_node [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#1f6f3f"><font color="white"><b>node</b> (mọi việc)</font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">node_type</td><td align="left">text</td><td>FK</td></tr><tr><td align="left">branch_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">visibility</td><td align="left">text</td><td></td></tr><tr><td align="left">title</td><td align="left">text</td><td></td></tr><tr><td align="left">status</td><td align="left">text</td><td></td></tr><tr><td align="left">created_by</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">completed_by</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">completed_at</td><td align="left">ts</td><td></td></tr></table>>];
    node_link [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#1f6f3f"><font color="white"><b>node_link</b> (cha-con M:N)</font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">parent_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">child_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">link_role</td><td align="left">text</td><td></td></tr><tr><td align="left">order_index</td><td align="left">int</td><td></td></tr><tr><td align="left">context_status</td><td align="left">text</td><td></td></tr></table>>];
    node_dependency [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#1f6f3f"><font color="white"><b>node_dependency</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">from_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">to_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">dep_type</td><td align="left">text</td><td></td></tr></table>>];
    task_bridge [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#1f6f3f"><font color="white"><b>task_bridge</b> (facade)</font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">customer_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">internal_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">is_result_source</td><td align="left">bool</td><td></td></tr></table>>];
  }

  // ============ C · EXTENSION (CTI) ============
  subgraph cluster_C {
    label="C · EXTENSION (CTI) — node_id vừa PK vừa FK"; style="rounded,filled"; fillcolor="#fbf3e6"; fontsize=13; color="#8a6d3b";
    node_visit [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_visit</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">patient_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">department_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">reception_time</td><td align="left">ts</td><td></td></tr><tr><td align="left">visit_object</td><td align="left">text</td><td></td></tr></table>>];
    node_room_session [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_room_session</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">room_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">staff_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">session_date</td><td align="left">date</td><td></td></tr><tr><td align="left">shift</td><td align="left">text</td><td></td></tr></table>>];
    node_exam [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_exam</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">service_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">reason</td><td align="left">text</td><td></td></tr><tr><td align="left">history</td><td align="left">text</td><td></td></tr><tr><td align="left">treatment</td><td align="left">text</td><td></td></tr></table>>];
    node_lab_order [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_lab_order</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">service_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">room_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">sample_time</td><td align="left">ts</td><td></td></tr><tr><td align="left">sample_quality</td><td align="left">text</td><td></td></tr></table>>];
    node_lab_result [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_lab_result</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">performed_by</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">approved_by</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">approved_at</td><td align="left">ts</td><td></td></tr></table>>];
    node_tx_course [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_tx_course</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">service_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">planned_sessions</td><td align="left">int</td><td></td></tr><tr><td align="left">date_from</td><td align="left">date</td><td></td></tr><tr><td align="left">date_to</td><td align="left">date</td><td></td></tr></table>>];
    node_tx_session [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#8a6d3b"><font color="white"><b>node_tx_session</b></font></td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>PK,FK</td></tr><tr><td align="left">session_number</td><td align="left">int</td><td></td></tr><tr><td align="left">performed_by</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">performed_at</td><td align="left">ts</td><td></td></tr></table>>];
    node_prescription [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="2" bgcolor="#b0a080"><font color="white"><b>node_prescription</b></font></td></tr><tr><td align="left">node_id</td><td>PK,FK</td></tr><tr><td colspan="2"><font point-size="9">(cột pha sau — Thuốc)</font></td></tr></table>>];
    node_followup [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="2" bgcolor="#b0a080"><font color="white"><b>node_followup</b></font></td></tr><tr><td align="left">node_id</td><td>PK,FK</td></tr><tr><td colspan="2"><font point-size="9">(cột pha sau — tái khám)</font></td></tr></table>>];
  }

  // ============ D · CHILD (multi-row) ============
  subgraph cluster_D {
    label="D · CHILD (nhiều dòng — 1NF)"; style="rounded,filled"; fillcolor="#f1ecf9"; fontsize=13; color="#6f42c1";
    diagnosis [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#6f42c1"><font color="white"><b>diagnosis</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">exam_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">icd_code</td><td align="left">text</td><td></td></tr><tr><td align="left">icd_yhct_code</td><td align="left">text</td><td></td></tr><tr><td align="left">is_primary</td><td align="left">bool</td><td></td></tr></table>>];
    lab_result_line [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#6f42c1"><font color="white"><b>lab_result_line</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">result_node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">analyte</td><td align="left">text</td><td></td></tr><tr><td align="left">value</td><td align="left">text</td><td></td></tr><tr><td align="left">unit</td><td align="left">text</td><td></td></tr><tr><td align="left">ref_low</td><td align="left">num</td><td></td></tr><tr><td align="left">ref_high</td><td align="left">num</td><td></td></tr><tr><td align="left">is_abnormal</td><td align="left">bool</td><td></td></tr></table>>];
    vital_measurement [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3"><tr><td colspan="3" bgcolor="#6f42c1"><font color="white"><b>vital_measurement</b></font></td></tr><tr><td align="left">id</td><td align="left">uuid</td><td>PK</td></tr><tr><td align="left">node_id</td><td align="left">uuid</td><td>FK</td></tr><tr><td align="left">measured_at</td><td align="left">ts</td><td></td></tr><tr><td align="left">weight_kg</td><td align="left">num</td><td></td></tr><tr><td align="left">height_cm</td><td align="left">num</td><td></td></tr><tr><td align="left">temp_c</td><td align="left">num</td><td></td></tr><tr><td align="left">pulse</td><td align="left">int</td><td></td></tr><tr><td align="left">bp_sys</td><td align="left">int</td><td></td></tr><tr><td align="left">bp_dia</td><td align="left">int</td><td></td></tr></table>>];
  }

  // ============ QUAN HỆ (FK) ============
  // Master hierarchy
  department -> branch;
  room -> department;
  staff -> branch;
  staff -> department;
  service -> service;

  // Core
  T_node -> node_type;
  T_node -> branch;
  node_link -> T_node [color="#1f6f3f"];
  node_link -> T_node [color="#1f6f3f"];
  node_dependency -> T_node [color="#1f6f3f"];
  node_dependency -> T_node [color="#1f6f3f"];
  task_bridge -> T_node [color="#b8860b"];
  task_bridge -> T_node [color="#b8860b"];

  // CTI extension -> node (1:1)
  node_visit -> T_node [color="#8a6d3b"];
  node_room_session -> T_node [color="#8a6d3b"];
  node_exam -> T_node [color="#8a6d3b"];
  node_lab_order -> T_node [color="#8a6d3b"];
  node_lab_result -> T_node [color="#8a6d3b"];
  node_tx_course -> T_node [color="#8a6d3b"];
  node_tx_session -> T_node [color="#8a6d3b"];
  node_prescription -> T_node [color="#8a6d3b", style=dashed];
  node_followup -> T_node [color="#8a6d3b", style=dashed];

  // Extension -> domain
  node_visit -> patient;
  node_room_session -> room;
  node_exam -> service;

  // Child -> parent
  diagnosis -> node_exam [color="#6f42c1"];
  lab_result_line -> node_lab_result [color="#6f42c1"];
  vital_measurement -> T_node [color="#6f42c1"];
}
